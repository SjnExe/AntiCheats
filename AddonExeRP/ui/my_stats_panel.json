{
    "namespace": "my_stats_panel",

    "main_panel@common.base_screen": {
        "$screen_content": "my_stats_panel.main_content",
        "$screen_bg_content": "common.screen_bg_content",
        "$close_on_player_hurt": false
    },

    "main_content": {
        "type": "panel",
        "size": [ "100%", "100%" ],
        "controls": [
            {
                "dialog_bg@common.dialog_bg_template": {
                    "size": [ 200, 150 ],
                    "layer": 1
                }
            },
            {
                "title_label@common.dialog_title_label": {
                    "layer": 2,
                    "text": "My Stats"
                }
            },
            {
                "stats_stack_panel": {
                    "type": "stack_panel",
                    "layer": 2,
                    "orientation": "vertical",
                    "size": [ "80%", "default" ],
                    "offset": [ 0, 20 ],
                    "controls": [
                        {
                            "rank_label@common.label": {
                                "text": "Rank: ",
                                "color": "$body_text_color"
                            }
                        },
                        {
                            "rank_value_owner@common.label": {
                                "text": "Owner",
                                "color": [ 1.0, 0.0, 0.0 ],
                                "bindings": [
                                    {
                                        "binding_type": "view",
                                        "source_property_name": "(not (query.has_tag('rank:Owner')))",
                                        "target_property_name": "#visible"
                                    }
                                ]
                            }
                        },
                        {
                            "rank_value_admin@common.label": {
                                "text": "Admin",
                                "color": [ 1.0, 0.5, 0.0 ],
                                "bindings": [
                                    {
                                        "binding_type": "view",
                                        "source_property_name": "(not (query.has_tag('rank:Admin')))",
                                        "target_property_name": "#visible"
                                    }
                                ]
                            }
                        },
                        {
                            "rank_value_member@common.label": {
                                "text": "Member",
                                "color": [ 0.5, 0.5, 0.5 ],
                                "bindings": [
                                    {
                                        "binding_type": "view",
                                        "source_property_name": "(not (query.has_tag('rank:Member')))",
                                        "target_property_name": "#visible"
                                    }
                                ]
                            }
                        },
                        {
                            "balance_label@common.label": {
                                "text": "Balance: ",
                                "color": "$body_text_color"
                            }
                        },
                        {
                            "balance_value@common.label": {
                                "text": "#balance_value",
                                "color": [ 0.0, 1.0, 0.0 ],
                                "bindings": [
                                    {
                                        "binding_type": "view",
                                        "source_property_name": "scoreboard('ae_balance')",
                                        "target_property_name": "#text"
                                    }
                                ]
                            }
                        },
                        {
                            "bounty_label@common.label": {
                                "text": "Bounty on you: ",
                                "color": "$body_text_color"
                            }
                        },
                        {
                            "bounty_value@common.label": {
                                "text": "#bounty_value",
                                "color": [ 1.0, 0.0, 0.0 ],
                                "bindings": [
                                    {
                                        "binding_type": "view",
                                        "source_property_name": "scoreboard('ae_bounty')",
                                        "target_property_name": "#text"
                                    }
                                ]
                            }
                        }
                    ]
                }
            },
            {
                "back_button@common.button": {
                    "layer": 2,
                    "size": [ 100, 20 ],
                    "anchor_from": "bottom_middle",
                    "anchor_to": "bottom_middle",
                    "offset": [ 0, -10 ],
                    "$pressed_button_name": "button.back",
                    "text": "Back"
                }
            }
        ]
    }
}
